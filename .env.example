# Neon PostgreSQL connection string (development branch).
# Copy this file to `.env` and fill in your Neon branch connection string.
# Use the pooled connection string for the app; Neon supports the standard
# Postgres protocol used by the node-postgres driver adapter.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth v5 (Auth.js). Generate AUTH_SECRET with `npx auth secret`.
AUTH_SECRET=

# GitHub OAuth app credentials.
# Create an app at https://github.com/settings/developers and set the callback
# URL to http://localhost:3000/api/auth/callback/github for local development.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Public base URL used to build links inside emails (no trailing slash).
# Defaults to http://localhost:3000 when unset.
APP_URL=http://localhost:3000

# Resend — transactional email (verification links).
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. `onboarding@resend.dev` is Resend's built-in test sender and
# needs no domain verification, but it can ONLY deliver to the email address
# that owns the Resend account. Swap in a verified domain to send anywhere.
EMAIL_FROM="DevStash <onboarding@resend.dev>"

# Email verification gate. Defaults to ON (any value other than `false`). Set to
# `false` to let new accounts register and log in without confirming their email
# — useful while no domain is linked to Resend, since the test sender only
# delivers to the Resend account owner and nobody else could verify.
EMAIL_VERIFICATION_ENABLED=true

# Upstash Redis — rate limiting on the auth endpoints (login, register,
# forgot/reset password, resend verification). Create a database at
# https://console.upstash.com and copy its REST URL + token.
# Leave both blank to disable rate limiting entirely: the limiter fails open,
# so an unconfigured (or unreachable) Upstash never blocks a request.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
