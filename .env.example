# Neon PostgreSQL connection string (development branch).
# Copy this file to `.env` and fill in your Neon branch connection string.
# Use the pooled connection string for the app; Neon supports the standard
# Postgres protocol used by the node-postgres driver adapter.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth v5 (Auth.js). Generate AUTH_SECRET with `npx auth secret`.
AUTH_SECRET=

# GitHub OAuth app credentials.
# Create an app at https://github.com/settings/developers and set the callback
# URL to http://localhost:3000/api/auth/callback/github for local development.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
